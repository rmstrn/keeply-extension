      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://127.0.0.1:5173/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173/)",
      "Bash(rm:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173/@vite/env)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173/@vite/client)",
      "Bash(findstr \"LISTENING\")",
      "Bash(curl -sv http://localhost:5173/@crx/client-worker)",
      "Bash(gh auth:*)"
    ]
  }
}
